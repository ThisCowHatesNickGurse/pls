local function hideClothes(char, record)
	if not char or not record then return end
	record.StoredClothes = record.StoredClothes or {}
	record.StoredClothes[char] = {}
	for _, v in pairs(char:GetChildren()) do
		if v:IsA("Clothing") or v:IsA("ShirtGraphic") then
			table.insert(record.StoredClothes[char], v)
			v.Parent = nil
		elseif v:IsA("Accessory") then
			if v:FindFirstChildWhichIsA("WrapLayer", true) then
				table.insert(record.StoredClothes[char], v)
				v.Parent = nil
			end
		end
	end
end

local function restoreClothes(record)
	if not record or not record.StoredClothes then return end
	for char, clothesList in pairs(record.StoredClothes) do
		for _, v in ipairs(clothesList) do
			if v and char and char.Parent then
				v.Parent = char
			end
		end
	end
end

local function weldMorphPiece(Character, MorphModel, morphPieceName, c0, c1)
	if not Character or not MorphModel then return end
	local torso = Character:FindFirstChild("Torso") or Character:FindFirstChild("UpperTorso") or Character:FindFirstChild("HumanoidRootPart")
	if not torso then return end
	local MorphPiece = MorphModel:FindFirstChild(morphPieceName)
	if MorphPiece then
		local part1 = MorphPiece:FindFirstChild("Middle") or MorphPiece
		if not part1 then return end
		local newm6d = torso:FindFirstChild("M6D"..MorphPiece.Name) or Instance.new("Motor6D")
		newm6d.Name = "M6D"..MorphPiece.Name; newm6d.Part0 = torso; newm6d.Part1 = part1; newm6d.C0 = c0 or CFrame.new(); newm6d.C1 = c1 or CFrame.new(); newm6d.Parent = torso; MorphPiece.Parent = Character
		if newm6d.Part1 then newm6d.Part1.Name = "M6D"..MorphPiece.Name end
	end
end

local function weldStaticPiece(Character, MorphModel, morphPieceName)
	if not Character or not MorphModel then return end
	local torso = Character:FindFirstChild("Torso") or Character:FindFirstChild("UpperTorso") or Character:FindFirstChild("HumanoidRootPart")
	if not torso then return end
	local MorphPiece = MorphModel:FindFirstChild(morphPieceName)
	if MorphPiece then
		local part1 = MorphPiece:FindFirstChild("Middle") or MorphPiece
		if not part1 then return end
		local weld = Instance.new("Weld")
		weld.Part0 = torso; weld.Part1 = part1; weld.C0 = CFrame.new(0,0,0); weld.Parent = torso; MorphPiece.Parent = Character
	end
end

local function CorrectColors(targ, character)
	if not character or not targ then return end
	local torso = character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
	if not torso then return end

	local targetColor = torso.Color

	local skinParts = {
		["color2"] = true, ["color3"] = true, ["color4"] = true, ["color5"] = true, ["color6"] = true,
		["Rod"] = true, ["Orbs"] = true, 
		["UpperL"] = true, ["UpperR"] = true, ["LowerL"] = true, ["LowerR"] = true,
		["UpperStatic"] = true, ["UpperStaticA"] = true, ["UpperStaticB"] = true,
		["LowerStatic"] = true, ["LowerStaticA"] = true,
		["Bru"] = true
	}

	local function applyColorsRecursively(obj)
		for _, v in pairs(obj:GetChildren()) do
			if v:IsA("BasePart") then
				v.Transparency = 0
				if v.Name == "Bra" or v:FindFirstChild("IsColor1") or v.Name == "c1" or v.Name == "color1" then
					v.Color = Color3.fromRGB(255,203,238)
				elseif skinParts[v.Name] or v:FindFirstChild("IsColor2") then
					v.Color = targetColor 
				elseif v.Name == "Particle1" or v:FindFirstChild("IsColor3") then v.Transparency = 1
				elseif v.Name == "Particle2" or v.Name == "Particle3" or v:FindFirstChild("IsColor4") then v.Transparency = 1
				else
					v.Color = targetColor
				end
				v.Anchored = false; v.CanCollide = false
				if v.Name == "Middle" or v:FindFirstChild("Hidden") then v.Transparency = 1 end
			elseif v:IsA("Model") or v:IsA("Folder") then
				applyColorsRecursively(v)
			end
		end
	end
	applyColorsRecursively(targ)
end

local function Weld(container)
	for _, v in pairs(container:GetChildren()) do
		if v:IsA("Model") or v:IsA("Folder") then
			Weld(v)
		elseif v:IsA("BasePart") then
			if container:FindFirstChild("Middle") then
				local Weldy = Instance.new("Weld"); Weldy.Part0 = container.Middle; Weldy.Part1 = v
				local CJ = CFrame.new(container.Middle.Position)
				local C0 = container.Middle.CFrame:inverse()*CJ; local C1 = v.CFrame:inverse()*CJ
				Weldy.C0 = C0; Weldy.C1 = C1; Weldy.Parent = container.Middle
			end
		end
	end
end

local function AddMorph(Morph, Character, IsBot)
	if not Character or not Morph or Morph == "" then return end
	if Character:FindFirstChild("Humanoid") == nil then return end

	local g = Morph:Clone()
	g.Parent = Character
	Weld(g)

	if IsBot and _G.BOTCorrectColors then
		_G.BOTCorrectColors(g, Character)
	else
		CorrectColors(g, Character)
	end

	for _, v in pairs(g:GetChildren()) do
		if Character:FindFirstChild(v.Name) then Character[v.Name]:Destroy() end
	end

	local torso = Character:FindFirstChild("Torso")
	if torso then
		weldMorphPiece(Character, g, "Rod", CFrame.new(0, -torso.Size.Y/2, -torso.Size.Z/2))
		weldMorphPiece(Character, g, "Orbs", CFrame.new(0, -torso.Size.Y/2, -torso.Size.Z/2))
		weldMorphPiece(Character, g, "UpperL", CFrame.new(-torso.Size.X/8, torso.Size.Y/2, -torso.Size.Z/2))
		weldMorphPiece(Character, g, "UpperR", CFrame.new(torso.Size.X/8, torso.Size.Y/2, -torso.Size.Z/2))
		weldMorphPiece(Character, g, "LowerL", CFrame.new(-torso.Size.X/8, -torso.Size.Y/2, torso.Size.Z/2))
		weldMorphPiece(Character, g, "LowerR", CFrame.new(torso.Size.X/8, -torso.Size.Y/2, torso.Size.Z/2))
		weldStaticPiece(Character, g, "UpperStatic")
		weldStaticPiece(Character, g, "UpperStaticA")
		weldStaticPiece(Character, g, "UpperStaticB")
		weldStaticPiece(Character, g, "LowerStatic")
		weldStaticPiece(Character, g, "LowerStaticA")
		weldStaticPiece(Character, g, "LowerStaticB")
	end
end

local function RemoveMorph(Morph, Character)
	if not Character or not Morph then return end
	for _, name in ipairs({"♀","♂","⚧"}) do
		local f = Character:FindFirstChild(name)
		if f then f:Destroy() end
	end

	local torso = Character:FindFirstChild("Torso") or Character:FindFirstChild("UpperTorso")
	if not torso then return end

	for _, part in pairs(Morph:GetChildren()) do
		local m6d = torso:FindFirstChild("M6D"..part.Name)
		if m6d then m6d:Destroy() end
	end
	for _, weld in pairs(torso:GetChildren()) do
		if weld:IsA("Weld") then
			local p1 = weld.Part1
			if p1 and Morph:FindFirstChild(p1.Name) then weld:Destroy() end
		end
	end
	for _, part in pairs(Morph:GetChildren()) do
		local charPart = Character:FindFirstChild(part.Name)
		if charPart then charPart:Destroy() end
	end
end

local function pickMorphTemplateForCharacter(character)
	if not character then return nil end
	local owner = Players:GetPlayerFromCharacter(character)
	local gender = nil
	local rawGender = safeGetAttribute(character, "Gender")

	if not rawGender and owner and PlayerIdentity[owner.UserId] then rawGender = PlayerIdentity[owner.UserId].Gender end
	if rawGender then gender = genderCategory(rawGender) end

	if gender == "female" then
		local femaleTemplate = hatsFolder:FindFirstChild("♀") or morphFolder:FindFirstChild("♀")
		if femaleTemplate then return femaleTemplate end
		local alt = hatsFolder:FindFirstChild("Female") or morphFolder:FindFirstChild("Female")
		if alt then return alt end
	elseif gender == "male" then 
		local maleTemplate = hatsFolder:FindFirstChild("♂") or morphFolder:FindFirstChild("♂")
		if maleTemplate then return maleTemplate end
		local alt = hatsFolder:FindFirstChild("Male") or morphFolder:FindFirstChild("Male")
		if alt then return alt end
	elseif gender == "femboy" then
		local fTemplate = hatsFolder:FindFirstChild("♂") or morphFolder:FindFirstChild("♂")
		if fTemplate then return fTemplate end
		local alt = hatsFolder:FindFirstChild("Male") or morphFolder:FindFirstChild("Male")
		if alt then return alt end
	end

	local template = hatsFolder:FindFirstChild("TaskHat")
	if not template then
		local hatsChildren = hatsFolder:GetChildren()
		if #hatsChildren > 0 then template = hatsChildren[1] end
	end
	if template then return template end

	local morphChildren = morphFolder:GetChildren()
	if #morphChildren > 0 then return morphChildren[1] end

	return nil
end

local function spawnMorphsForPair(charARef, charBRef, record)
	if not record then return end
	record.SpawnedHats = record.SpawnedHats or {}

	local participants = {charARef, charBRef}
	for _, p in ipairs(participants) do
		if p then
			local character = nil
			if typeof(p) == "Instance" then
				if p:IsA("Player") then character = p.Character end
				if p:IsA("Model") and p:FindFirstChildOfClass("Humanoid") then character = p end
			end
			if character and character:IsA("Model") then
				local template = pickMorphTemplateForCharacter(character)
				if template then
					pcall(function() AddMorph(template, character, false) end)
					table.insert(record.SpawnedHats, {Character = character, Template = template})
				end
			end
		end
	end
end

local function removeSpawnedMorphs(record)
	if not record or not record.SpawnedHats then return end
	for _, rec in ipairs(record.SpawnedHats) do
		if rec and rec.Character and rec.Template then
			pcall(function() RemoveMorph(rec.Template, rec.Character) end)
		end
	end
	record.SpawnedHats = nil
end

