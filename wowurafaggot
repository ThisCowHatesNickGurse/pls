local function RemoveSword(player)
	if not player then return end
	local char = player.Character
	if char then
		local tool = char:FindFirstChild("Sword")
		if tool then tool:Destroy() end
	end
	local backpack = player:FindFirstChild("Backpack")
	if backpack then
		local tool = backpack:FindFirstChild("Sword")
		if tool then tool:Destroy() end
	end
end

local function GiveSword(player)
	if not isGameActive then return end
	if not player or not player.Character then return end

	local char = player.Character
	if char:GetAttribute("IsRagdolled") or char:GetAttribute("InFinisher") then return end

	local backpack = player:FindFirstChild("Backpack")
	if not backpack then return end

	if char:FindFirstChild("Sword") or backpack:FindFirstChild("Sword") then return end

	local swordTemplate = ServerStorage:FindFirstChild("Sword") or ReplicatedStorage:FindFirstChild("Sword")
	if swordTemplate and swordTemplate:IsA("Tool") then
		local newSword = swordTemplate:Clone()
		newSword.Parent = backpack
	end
end

