morphEvent.OnServerEvent:Connect(function(player, action, arg1)
	local char = player.Character
	if not char then return end

	if action == "MORPH" then
		if arg1 == "Reset" then player:LoadCharacter() else
			local m = morphFolder:FindFirstChild(arg1)
			if m and char then
				for _, v in pairs(char:GetChildren()) do if v:IsA("Accessory") or v:IsA("Clothing") then v:Destroy() end end
				for _, v in pairs(m:GetChildren()) do v:Clone().Parent = char end
			end
		end
	end
end)

CastVoteEvent.OnServerEvent:Connect(function(player, mapName)
	if table.find(validOptions, mapName) then
		votes[player] = mapName
		table.clear(tallies) -- Fixed: use table.clear() instead of creating a new {} table to keep memory references intact
		for _, v in pairs(votes) do
			tallies[v] = (tallies[v] or 0) + 1
		end
		UpdateVotesEvent:FireAllClients(tallies)
	end
end)

-- Main Game Loop
task.spawn(function()
	while true do
		isGameActive = false
		isVoting = false
		table.clear(votes)
		table.clear(tallies)
		table.clear(validOptions)

		local allMapKeys = {}
		for mapName, _ in pairs(Maps) do table.insert(allMapKeys, mapName) end

		for i = #allMapKeys, 2, -1 do
			local j = math.random(i)
			allMapKeys[i], allMapKeys[j] = allMapKeys[j], allMapKeys[i]
		end

		for i = 1, math.min(3, #allMapKeys) do table.insert(validOptions, allMapKeys[i]) end

		isVoting = true
		VoteStartEvent:FireAllClients(validOptions, VOTE_TIME)

		for i = VOTE_TIME, 0, -1 do
			voteTimeLeft = i
			TimerUpdateEvent:FireAllClients("Voting Ends In: " .. voteTimeLeft)
			task.wait(1)
		end

		isVoting = false

		local winningMapName = validOptions[1] 
		local highestVotes = -1
		for mapName, count in pairs(tallies) do
			if count > highestVotes then
				highestVotes = count
				winningMapName = mapName
			end
		end

		TimerUpdateEvent:FireAllClients("Loading: " .. winningMapName .. "...")
		task.wait(2) 

		-- Load Map and Apply Lighting
		local dataUrl = Maps[winningMapName]
		activeMapModel = Serializer.Map.LoadFromURL(dataUrl, workspace)

		-- Decode and apply the lighting for the winning map
		ApplyLighting(MapLightingStrings[winningMapName])

		isGameActive = true

		if activeMapModel and activeMapModel:FindFirstChild("Spawns") then
			teleportPlayersTo(activeMapModel.Spawns, Players:GetPlayers())

			for _, p in ipairs(Players:GetPlayers()) do
				GiveSword(p)
			end
		end

		for i = (GAME_TIME - VOTE_TIME), 0, -1 do
			local minutes = math.floor(i / 60)
			local seconds = i % 60
			TimerUpdateEvent:FireAllClients(string.format("Next Game In: %02d:%02d", minutes, seconds))
			task.wait(1)
		end

		isGameActive = false

		if activeMapModel then
			activeMapModel:Destroy()
			activeMapModel = nil
		end

		ClearLighting()

		local lobbySpawns = workspace:FindFirstChild("Lobby") and workspace.Lobby:FindFirstChild("Spawns")
		teleportPlayersTo(lobbySpawns, Players:GetPlayers())

		for _, p in ipairs(Players:GetPlayers()) do
			RemoveSword(p)
		end
	end
end)
