local function teleportPlayersTo(spawnFolder, playersToMove)
	if not spawnFolder then return end

	local spawns = {}
	for _, item in ipairs(spawnFolder:GetChildren()) do
		if item:IsA("BasePart") or item:IsA("SpawnLocation") then
			item.CanCollide = false
			table.insert(spawns, item)
		end
	end

	if #spawns == 0 then return end

	for _, player in ipairs(playersToMove) do
		if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
			local randomSpawn = spawns[math.random(1, #spawns)]
			player.Character.HumanoidRootPart.CFrame = randomSpawn.CFrame + Vector3.new(0, 3, 0)
		end
	end
end

