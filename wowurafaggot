local function setupHealthListener(character)
	local humanoid = character:WaitForChild("Humanoid")
	local currentHP = humanoid.Health
	local isReverting = false

	humanoid.HealthChanged:Connect(function(hp)
		if isReverting then return end

		if character:GetAttribute("Invincible") and hp > 0 then
			if hp < currentHP then
				isReverting = true
				humanoid.Health = currentHP
				isReverting = false
				return
			end
		end

		currentHP = humanoid.Health

		if hp >= 100 and character:GetAttribute("IsRagdolled") and not character:GetAttribute("InFinisher") then
			character:SetAttribute("IsRagdolled", false)
			character:SetAttribute("Invincible", false)

			humanoid.PlatformStand = false
			humanoid.WalkSpeed = 16 

			Ragdoll.UnRagdollCharacter(character)

			local hrp = character:FindFirstChild("HumanoidRootPart")
			if hrp then
				local prompt = hrp:FindFirstChild("FinishPrompt")
				if prompt then prompt:Destroy() end
			end
		end

		if hp > 0 and hp <= 75 and not character:GetAttribute("IsRagdolled") and not character:GetAttribute("InFinisher") then
			character:SetAttribute("IsRagdolled", true)
			character:SetAttribute("Invincible", true)

			humanoid.PlatformStand = true
			humanoid.WalkSpeed = 0

			Ragdoll.RagdollCharacter(character)

			local hrp = character:FindFirstChild("HumanoidRootPart")
			local prompt = Instance.new("ProximityPrompt")
			prompt.Name = "FinishPrompt"
			prompt.ActionText = "Finish"
			prompt.ObjectText = character.Name
			prompt.HoldDuration = 0.5
			prompt.RequiresLineOfSight = false
			if hrp then prompt.Parent = hrp end

			local ownerPlayer = Players:GetPlayerFromCharacter(character)

			prompt.Triggered:Connect(function(finisherPlayer)
				local fChar = finisherPlayer.Character
				if fChar and fChar:GetAttribute("IsRagdolled") then return end

				if fChar and fChar:FindFirstChild("Humanoid") and fChar.Humanoid.Health > 0 then
					prompt:Destroy()
					local target = ownerPlayer or character
					StartFinisherSequence(finisherPlayer, target)
				end
			end)

			task.spawn(function()
				while character and character.Parent and character:GetAttribute("IsRagdolled") and not character:GetAttribute("InFinisher") do
					task.wait(1.5)
					if humanoid.Health > 0 and humanoid.Health < humanoid.MaxHealth then
						humanoid.Health = math.min(humanoid.MaxHealth, humanoid.Health + 1)
					end
				end
			end)
		end
	end)
end

local function setupPlayer(player)
	-- Leaderstats setup
	local ls = Instance.new("Folder")
	ls.Name = "leaderstats"
	ls.Parent = player
	local kills = Instance.new("IntValue")
	kills.Name = "Kills"
	kills.Value = 0
	kills.Parent = ls

	-- Identity & Client Prompt
	PlayerIdentity[player.UserId] = {Gender = "New", Age = "?"}
	TaskEvent:FireClient(player, "PROMPT_SETUP")

	player.CharacterAdded:Connect(function(c)
		wait(2)
		print("[SPAWN DEBUG] CharacterAdded fired for:", player.Name)

		-- 1. Wait for the crucial character parts to load first!
		local hum = c:WaitForChild("Humanoid", 10)
		local hrp = c:WaitForChild("HumanoidRootPart", 10)
		local head = c:WaitForChild("Head", 10)

		if not hrp then 
			warn("[SPAWN DEBUG] Failed to find HumanoidRootPart for " .. player.Name .. " within 10 seconds!")
			return 
		end 

		print("[SPAWN DEBUG] Character parts loaded successfully for:", player.Name)

		-- Finisher Setup logic
		local id2 = PlayerIdentity[player.UserId]
		if id2 and c.SetAttribute then pcall(function() c:SetAttribute("Gender", id2.Gender); c:SetAttribute("Age", id2.Age) end) end
		updateOverheadName(c, player.DisplayName)
		task.spawn(setupHealthListener, c)

		-- 2. Map Voting & Spawn Teleport logic
		if isVoting and voteTimeLeft > 0 then
			VoteStartEvent:FireClient(player, validOptions, voteTimeLeft)
		end

		print("[SPAWN DEBUG] Game Active Status:", isGameActive)

		if isGameActive and activeMapModel and activeMapModel:FindFirstChild("Spawns") then
			print("[SPAWN DEBUG] Teleporting to Active Map Spawns.")
			teleportPlayersTo(activeMapModel.Spawns, {player})
		else
			print("[SPAWN DEBUG] Attempting to teleport to Lobby Spawns...")
			local lobby = workspace:FindFirstChild("Lobby")
			if not lobby then
				warn("[SPAWN DEBUG ERROR] There is no model/folder named 'Lobby' in the Workspace!")
				return
			end

			local lobbySpawns = lobby:FindFirstChild("Spawns")
			if lobbySpawns then
				print("[SPAWN DEBUG] Found workspace.Lobby.Spawns! Teleporting player now.")
				teleportPlayersTo(lobbySpawns, {player})
			else
				warn("[SPAWN DEBUG ERROR] Found 'Lobby', but could not find a 'Spawns' folder inside it!")
			end
		end
	end)
	-- Check for pre-existing character on late joins
	if player.Character and player.Character.Parent then
		task.spawn(function()
			pcall(function() player.Character:WaitForChild("Humanoid",10); player.Character:WaitForChild("Head",10) end)
			updateOverheadName(player.Character, player.DisplayName)
			task.spawn(setupHealthListener, player.Character)
		end)
	end
end

Players.PlayerAdded:Connect(setupPlayer)

Players.PlayerRemoving:Connect(function(p)
	local activeAsFinisher = ActiveFinishers[p.UserId]
	if activeAsFinisher then
		CleanupFinisher(p.UserId)
	else
		for fid, data in pairs(ActiveFinishers) do
			if data.Victim == p then
				CleanupFinisher(fid)
				break
			end
		end
	end

	if PlayerDummies[p] then
		PlayerDummies[p]:Destroy()
		PlayerDummies[p] = nil
	end

	PlayerIdentity[p.UserId] = nil
end)

