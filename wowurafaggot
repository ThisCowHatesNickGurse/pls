local function stopCurrentAnimation(playerOrChar)
	if not Animator then return false end
	local name = nil
	if typeof(playerOrChar) == "Instance" then
		if playerOrChar:IsA("Player") then
			if playerOrChar.Character then name = playerOrChar.Character.Name end
		elseif playerOrChar:IsA("Model") then
			name = playerOrChar.Name
		end
	end
	if not name then return false end
	local animFolder = workspace:FindFirstChild("boisus")
	if not animFolder then return false end
	local animScript = animFolder:FindFirstChild(name)
	if animScript then
		pcall(function() Animator.StopAnimation(animScript) end)
		animScript:Destroy()
		return true
	end
	return false
end

local function changeSpeedForChar(characterOrModel, speed)
	if not Animator or not Animator.ChangeAnimationSpeed then return end
	if not characterOrModel then return end
	local name = characterOrModel.Name
	local animFolder = workspace:FindFirstChild("boisus")
	if animFolder then
		local animScript = animFolder:FindFirstChild(name)
		if animScript then
			pcall(function() Animator.ChangeAnimationSpeed(animScript, speed) end)
		end
	end
end

local function getAnimFromFolder(displayName, roleType)
	if not displayName or displayName == "" then return nil end

	for _, category in ipairs(animsFolder:GetChildren()) do
		if category:IsA("Folder") then
			local root = category:FindFirstChild(displayName)
			if root then
				local anim = root:FindFirstChild(roleType)
				if anim and (anim:IsA("KeyframeSequence") or anim:IsA("Animation")) then 
					return anim 
				end
			end
		end
	end
	return nil
end

