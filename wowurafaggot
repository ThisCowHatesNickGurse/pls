local lobbyLightingCache = {}
for _, child in ipairs(LightingService:GetChildren()) do
	if child:IsA("Sky") or child:IsA("Atmosphere") or child:IsA("PostEffect") then
		table.insert(lobbyLightingCache, child:Clone())
	end
