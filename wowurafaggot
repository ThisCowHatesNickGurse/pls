--------------------------------------------------------------------
local function genderCategory(val)
	if not val then return "neutral" end
	local s = tostring(val):lower()
	if s:find("femboy") or s:find("⚧") then return "femboy" end
	if s:find("♂") or s:find("male") or s == "m" or s == "man" then return "male" end
	if s:find("♀") or s:find("female") or s == "f" or s == "woman" then return "female" end
	return "neutral"
end

local function safeGetAttribute(inst, name)
	if not inst or not inst.GetAttribute then return nil end
	local ok, val = pcall(function() return inst:GetAttribute(name) end)
	if ok then return val end
	return nil
end

local function getPlayerGender(player)
	if not player then return "neutral" end
	
	local id = PlayerIdentity[player.UserId]
	if id and id.Gender and id.Gender ~= "New" and id.Gender ~= "" then 
		return genderCategory(id.Gender) 
	end
	
	if player.Character then
		local g = safeGetAttribute(player.Character, "Gender")
		if g and g ~= "New" and g ~= "" then 
			return genderCategory(g) 
		end
		
		local head = player.Character:FindFirstChild("Head")
		if head then
			local bb = head:FindFirstChild("RP_Billboard")
			if bb then
				local infoLabel = bb:FindFirstChild("InfoLabel")
				if infoLabel and infoLabel.Text then
					local splitText = string.split(infoLabel.Text, "|")
					if #splitText >= 2 then
						local extractedGender = splitText[#splitText]:match("^%s*(.-)%s*$")
						if extractedGender and extractedGender ~= "New" and extractedGender ~= "" then
							return genderCategory(extractedGender)
						end
					end
				end
			end
		end
	end
	
	return "neutral"
end

local function safeCreateOverhead(character, newName)
	if not character then return end
	local ok, head = pcall(function() return character:WaitForChild("Head", 10) end)
	if not ok or not head then return end

	local bb = head:FindFirstChild("RP_Billboard")
	if not bb then
		bb = Instance.new("BillboardGui")
		bb.Name = "RP_Billboard"; bb.Adornee = head; bb.Size = UDim2.new(6,0,1.2,0); bb.StudsOffset = Vector3.new(0,2.8,0); bb.AlwaysOnTop = false; bb.MaxDistance = 80; bb.LightInfluence = 0; bb.Parent = head
		local nameLabel = Instance.new("TextLabel"); nameLabel.Name = "RPName"; nameLabel.Size = UDim2.new(1,0,0.6,0); nameLabel.Position = UDim2.new(0,0,0,0); nameLabel.BackgroundTransparency = 1; nameLabel.TextScaled = true; nameLabel.Font = Enum.Font.FredokaOne; nameLabel.TextStrokeTransparency = 0; nameLabel.Parent = bb
		local infoLabel = Instance.new("TextLabel"); infoLabel.Name = "InfoLabel"; infoLabel.Size = UDim2.new(1,0,0.3,0); infoLabel.Position = UDim2.new(0,0,0.6,0); infoLabel.BackgroundTransparency = 1; infoLabel.TextScaled = true; infoLabel.Font = Enum.Font.GothamBold; infoLabel.TextStrokeTransparency = 0; infoLabel.Parent = bb
	end

	if bb:FindFirstChild("RPName") then
		bb.RPName.Text = tostring(newName or character.Name)
		bb.RPName.TextColor3 = Color3.fromRGB(255,255,255)
	end

	local gattr = safeGetAttribute(character, "Gender")
	local aattr = safeGetAttribute(character, "Age")
	if (not gattr or not aattr) then
		local ply = Players:GetPlayerFromCharacter(character)
		if ply and PlayerIdentity[ply.UserId] then
			gattr = gattr or PlayerIdentity[ply.UserId].Gender
			aattr = aattr or PlayerIdentity[ply.UserId].Age
		end
	end
	local ageText = aattr or "?"
	local genderText = gattr or "New"

	if bb:FindFirstChild("InfoLabel") then
		bb.InfoLabel.Text = string.format("%s  |  %s", ageText, genderText)
		local cat = genderCategory(genderText)
		if cat == "male" then bb.InfoLabel.TextColor3 = Color3.fromRGB(140,190,255)
		elseif cat == "female" then bb.InfoLabel.TextColor3 = Color3.fromRGB(255,150,200)
		elseif cat == "femboy" then bb.InfoLabel.TextColor3 = Color3.fromRGB(180,130,255)
		else bb.InfoLabel.TextColor3 = Color3.fromRGB(200,200,200) end
	end
end

local function updateOverheadName(character, newName)
	pcall(function() safeCreateOverhead(character, newName) end)
end

