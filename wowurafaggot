-- Lighting Decoder Functions
local function ClearLighting()
	local removableClasses = {
		Atmosphere = true, Sky = true, BloomEffect = true, 
		BlurEffect = true, DepthOfFieldEffect = true, 
		SunRaysEffect = true, ColorCorrectionEffect = true
	}

	for _, child in ipairs(game.Lighting:GetChildren()) do
		if removableClasses[child.ClassName] then
			child:Destroy()
		end
	end
end

local function ApplyLighting(jsonString)
	ClearLighting()

	if not jsonString or jsonString == "" then return end

	local success, data = pcall(function()
		return HttpService:JSONDecode(jsonString)
	end)

	if not success or not data then return end

	for _, objData in ipairs(data) do
		local newObj = Instance.new(objData.ClassName)
		newObj.Name = objData.Name

		for prop, value in pairs(objData.Properties) do
			if type(value) == "table" and value.r and value.g and value.b then
				newObj[prop] = Color3.new(value.r, value.g, value.b)
			else
				newObj[prop] = value
			end
		end

		newObj.Parent = game.Lighting
	end
end

