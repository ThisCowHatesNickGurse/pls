local function createCustomPrompt(name, actionText, objectText, keycode, offset)
	local prompt = Instance.new("ProximityPrompt")
	prompt.Name = name
	prompt.ActionText = actionText
	prompt.ObjectText = objectText
	prompt.KeyboardKeyCode = keycode
	prompt.UIOffset = offset
	prompt.Style = Enum.ProximityPromptStyle.Custom 
	prompt.RequiresLineOfSight = false
	prompt.MaxActivationDistance = 8
	return prompt
end

-- Reusable Carry Toggle Function 
local function ToggleCarry(targetCharacter, carrierPlayer, carryPrompt)
	local cChar = carrierPlayer.Character
	if cChar and cChar:GetAttribute("IsRagdolled") then return end
	
	local carrierHrp = cChar:FindFirstChild("HumanoidRootPart")
	local hrp = targetCharacter:FindFirstChild("HumanoidRootPart")
	if not carrierHrp or not hrp then return end

	local isCarried = targetCharacter:GetAttribute("IsCarried")
	local currentCarrierId = targetCharacter:GetAttribute("CarrierUserId")
	
	local finishPrompt = hrp:FindFirstChild("FinishPrompt")
	local executePrompt = hrp:FindFirstChild("ExecutePrompt")

	if not isCarried then
		-- START CARRYING
		targetCharacter:SetAttribute("IsCarried", true)
		targetCharacter:SetAttribute("CarrierUserId", carrierPlayer.UserId)
		
		if carryPrompt then
			carryPrompt.ActionText = "Drop"
			carryPrompt.KeyboardKeyCode = Enum.KeyCode.Q 
		end
		if finishPrompt then finishPrompt.Enabled = false end
		if executePrompt then executePrompt.Enabled = false end
		
		local weld = hrp:FindFirstChild("CarryWeld") or Instance.new("Weld")
		weld.Name = "CarryWeld"
		weld.Part0 = carrierHrp
		weld.Part1 = hrp
		weld.C0 = CFrame.new(0, 1, 1) * CFrame.Angles(math.rad(-90), 0, 0) 
		weld.Parent = hrp
		
		for _, part in ipairs(targetCharacter:GetDescendants()) do
			if part:IsA("BasePart") then
				part.Massless = true
				part.CanCollide = false
			end
		end

		-- Setup 3-Jump Drop Listener
		local carrierHum = cChar:FindFirstChild("Humanoid")
		if carrierHum then
			local jumpCount = 0
			local lastJumpTime = 0
			local connId = carrierPlayer.UserId .. "_" .. targetCharacter.Name
			
			if ActiveCarryConnections[connId] then
				ActiveCarryConnections[connId]:Disconnect()
			end
			
			ActiveCarryConnections[connId] = carrierHum.StateChanged:Connect(function(old, new)
				if new == Enum.HumanoidStateType.Jumping then
					local now = tick()
					if now - lastJumpTime > 1.5 then -- Reset jump sequence count if too much time passes
						jumpCount = 1
					else
						jumpCount += 1
					end
					lastJumpTime = now
					
					if jumpCount >= 3 then
						ToggleCarry(targetCharacter, carrierPlayer, carryPrompt)
					end
				end
			end)
		end
	else
		-- DROP
		if currentCarrierId ~= carrierPlayer.UserId then return end

		targetCharacter:SetAttribute("IsCarried", false)
		targetCharacter:SetAttribute("CarrierUserId", nil)
		
		if carryPrompt then
			carryPrompt.ActionText = "Carry"
			carryPrompt.KeyboardKeyCode = Enum.KeyCode.C 
		end
		if finishPrompt then finishPrompt.Enabled = true end
		if executePrompt then executePrompt.Enabled = true end
		
		if hrp:FindFirstChild("CarryWeld") then
			hrp.CarryWeld:Destroy()
		end
		
		for _, part in ipairs(targetCharacter:GetDescendants()) do
			if part:IsA("BasePart") then
				part.Massless = false
			end
		end

		local connId = carrierPlayer.UserId .. "_" .. targetCharacter.Name
		if ActiveCarryConnections[connId] then
			ActiveCarryConnections[connId]:Disconnect()
			ActiveCarryConnections[connId] = nil
		end
	end
end


local function setupHealthListener(character)
	local humanoid = character:WaitForChild("Humanoid")
	local currentHP = humanoid.Health
	local isReverting = false
	local ownerPlayer = Players:GetPlayerFromCharacter(character)

	humanoid.HealthChanged:Connect(function(hp)
		if isReverting then return end

		if character:GetAttribute("Invincible") and hp > 0 then
			if hp < currentHP then
				isReverting = true
				humanoid.Health = currentHP
				isReverting = false
				return
			end
		end

		currentHP = humanoid.Health

		-- UNRAGDOLL TRIGGER
		if hp >= 100 and character:GetAttribute("IsRagdolled") and not character:GetAttribute("InFinisher") then
			character:SetAttribute("IsRagdolled", false)
			character:SetAttribute("Invincible", false)
			character:SetAttribute("IsCarried", false) 
			character:SetAttribute("CarrierUserId", nil) 

			humanoid.PlatformStand = false
			humanoid.WalkSpeed = 16 

			Ragdoll.UnRagdollCharacter(character)
			GiveSword(ownerPlayer) 

			local torso = character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
			if torso and torso:FindFirstChild("CarryClickDetector") then
				torso.CarryClickDetector:Destroy()
			end

			local carrierId = character:GetAttribute("CarrierUserId")
			if carrierId then
				local connId = carrierId .. "_" .. character.Name
				if ActiveCarryConnections[connId] then
					ActiveCarryConnections[connId]:Disconnect()
					ActiveCarryConnections[connId] = nil
				end
			end

			local hrp = character:FindFirstChild("HumanoidRootPart")
			if hrp then
				if hrp:FindFirstChild("FinishPrompt") then hrp.FinishPrompt:Destroy() end
				if hrp:FindFirstChild("ExecutePrompt") then hrp.ExecutePrompt:Destroy() end
				if hrp:FindFirstChild("CarryPrompt") then hrp.CarryPrompt:Destroy() end
				if hrp:FindFirstChild("CarryWeld") then hrp.CarryWeld:Destroy() end
			end
		end

		-- RAGDOLL TRIGGER
		if hp > 0 and hp <= 75 and not character:GetAttribute("IsRagdolled") and not character:GetAttribute("InFinisher") then
			character:SetAttribute("IsRagdolled", true)
			character:SetAttribute("Invincible", true)

			humanoid.PlatformStand = true
			humanoid.WalkSpeed = 0

			Ragdoll.RagdollCharacter(character)
			RemoveSword(ownerPlayer) 

			-- Add ClickDetector to Torso for Double Click Carrying
			local torso = character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
			if torso then
				local cd = Instance.new("ClickDetector")
				cd.Name = "CarryClickDetector"
				cd.MaxActivationDistance = 10
				cd.Parent = torso

				local lastClicks = {}
				cd.MouseClick:Connect(function(clicker)
					local now = tick()
					if lastClicks[clicker] and (now - lastClicks[clicker]) <= 0.5 then
						-- Detected a double click
						local hrp = character:FindFirstChild("HumanoidRootPart")
						ToggleCarry(character, clicker, hrp and hrp:FindFirstChild("CarryPrompt"))
						lastClicks[clicker] = 0 -- Reset
					else
						lastClicks[clicker] = now
					end
				end)
			end

			local hrp = character:FindFirstChild("HumanoidRootPart")
			
			if hrp then
				local finishPrompt = createCustomPrompt("FinishPrompt", "Finish", character.Name, Enum.KeyCode.F, Vector2.new(60, 0))
				finishPrompt.Parent = hrp

				local executePrompt = createCustomPrompt("ExecutePrompt", "Execute", character.Name, Enum.KeyCode.X, Vector2.new(-60, 0))
				executePrompt.Parent = hrp

				local carryPrompt = createCustomPrompt("CarryPrompt", "Carry", character.Name, Enum.KeyCode.C, Vector2.new(0, -60))
				carryPrompt.Parent = hrp

				finishPrompt.Triggered:Connect(function(finisherPlayer)
					local fChar = finisherPlayer.Character
					if fChar and fChar:GetAttribute("IsRagdolled") then return end

					if fChar and fChar:FindFirstChild("Humanoid") and fChar.Humanoid.Health > 0 then
						finishPrompt:Destroy()
						executePrompt:Destroy()
						carryPrompt:Destroy()
						local target = ownerPlayer or character
						StartFinisherSequence(finisherPlayer, target)
					end
				end)

				executePrompt.Triggered:Connect(function(executorPlayer)
					local eChar = executorPlayer.Character
					if eChar and eChar:GetAttribute("IsRagdolled") then return end

					if eChar and eChar:FindFirstChild("Humanoid") and eChar.Humanoid.Health > 0 then
						local leaderstats = executorPlayer:FindFirstChild("leaderstats")
						if leaderstats and leaderstats:FindFirstChild("Kills") then
							leaderstats.Kills.Value += 1
						end
						
						character:SetAttribute("Invincible", false)
						humanoid.Health = 0
						
						finishPrompt:Destroy()
						executePrompt:Destroy()
						carryPrompt:Destroy()
					end
				end)

				carryPrompt.Triggered:Connect(function(carrierPlayer)
					ToggleCarry(character, carrierPlayer, carryPrompt)
				end)
			end

			task.spawn(function()
				while character and character.Parent and character:GetAttribute("IsRagdolled") and not character:GetAttribute("InFinisher") do
					task.wait(1.5)
					if not character:GetAttribute("IsCarried") then -- Prevents health regeneration while being carried
						if humanoid.Health > 0 and humanoid.Health < humanoid.MaxHealth then
							humanoid.Health = math.min(humanoid.MaxHealth, humanoid.Health + 1)
						end
					end
				end
			end)
		end
	end)
end
local function setupPlayer(player)
	local ls = Instance.new("Folder")
	ls.Name = "leaderstats"
	ls.Parent = player
	local kills = Instance.new("IntValue")
	kills.Name = "Kills"
	kills.Value = 0
	kills.Parent = ls

	PlayerIdentity[player.UserId] = {Gender = "New", Age = "?"}
	TaskEvent:FireClient(player, "PROMPT_SETUP")

	player.CharacterAdded:Connect(function(c)
		local hum = c:WaitForChild("Humanoid", 10)
		local hrp = c:WaitForChild("HumanoidRootPart", 10)
		local head = c:WaitForChild("Head", 10)
		if not hrp then return end 

		local id2 = PlayerIdentity[player.UserId]
		if id2 and c.SetAttribute then pcall(function() c:SetAttribute("Gender", id2.Gender); c:SetAttribute("Age", id2.Age) end) end
		updateOverheadName(c, player.DisplayName)
		task.spawn(setupHealthListener, c)

		if isVoting and voteTimeLeft > 0 then
			VoteStartEvent:FireClient(player, validOptions, voteTimeLeft)
		end

		if isGameActive and activeMapModel and activeMapModel:FindFirstChild("Spawns") then
			teleportPlayersTo(activeMapModel.Spawns, {player})
			GiveSword(player) 
		else
			RemoveSword(player) 
			local lobby = workspace:FindFirstChild("Lobby")
			if not lobby then return end
			local lobbySpawns = lobby:FindFirstChild("Spawns")
			if lobbySpawns then
				teleportPlayersTo(lobbySpawns, {player})
			end
		end
	end)
	
	if player.Character and player.Character.Parent then
		task.spawn(function()
			pcall(function() player.Character:WaitForChild("Humanoid",10); player.Character:WaitForChild("Head",10) end)
			updateOverheadName(player.Character, player.DisplayName)
			task.spawn(setupHealthListener, player.Character)
		end)
	end
end

Players.PlayerAdded:Connect(setupPlayer)

Players.PlayerRemoving:Connect(function(p)
	local activeAsFinisher = ActiveFinishers[p.UserId]
	if activeAsFinisher then
		CleanupFinisher(p.UserId)
	else
		for fid, data in pairs(ActiveFinishers) do
			if data.Victim == p then
				CleanupFinisher(fid)
				break
			end
		end
	end

	if PlayerDummies[p] then
		PlayerDummies[p]:Destroy()
		PlayerDummies[p] = nil
	end

	PlayerIdentity[p.UserId] = nil
end)

for _, p in pairs(Players:GetPlayers()) do
	task.spawn(function() setupPlayer(p) end)
end

