local function applyMapLighting(mapName)
	for _, child in ipairs(LightingService:GetChildren()) do
		if child:IsA("Sky") or child:IsA("Atmosphere") or child:IsA("PostEffect") then
			child:Destroy()
		end
	end

	if mapName == "Lobby" then
		for _, obj in ipairs(lobbyLightingCache) do
			obj:Clone().Parent = LightingService
		end
	else
		local mapFolder = lightingFolders:FindFirstChild(mapName)
		if mapFolder then
			for _, obj in ipairs(mapFolder:GetChildren()) do
				obj:Clone().Parent = LightingService
			end
		else
			warn("No lighting folder found for map: " .. tostring(mapName))
			for _, obj in ipairs(lobbyLightingCache) do
				obj:Clone().Parent = LightingService
			end
		end
	end
end
