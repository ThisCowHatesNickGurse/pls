	if not character then return end
	local ok, head = pcall(function() return character:WaitForChild("Head", 10) end)
	if not ok or not head then return end

	local bb = head:FindFirstChild("RP_Billboard")
	if not bb then
		bb = Instance.new("BillboardGui")
		bb.Name = "RP_Billboard"; bb.Adornee = head; bb.Size = UDim2.new(6,0,1.2,0); bb.StudsOffset = Vector3.new(0,2.8,0); bb.AlwaysOnTop = false; bb.MaxDistance = 80; bb.LightInfluence = 0; bb.Parent = head
		local nameLabel = Instance.new("TextLabel"); nameLabel.Name = "RPName"; nameLabel.Size = UDim2.new(1,0,0.6,0); nameLabel.Position = UDim2.new(0,0,0,0); nameLabel.BackgroundTransparency = 1; nameLabel.TextScaled = true; nameLabel.Font = Enum.Font.FredokaOne; nameLabel.TextStrokeTransparency = 0; nameLabel.Parent = bb
		local infoLabel = Instance.new("TextLabel"); infoLabel.Name = "InfoLabel"; infoLabel.Size = UDim2.new(1,0,0.3,0); infoLabel.Position = UDim2.new(0,0,0.6,0); infoLabel.BackgroundTransparency = 1; infoLabel.TextScaled = true; infoLabel.Font = Enum.Font.GothamBold; infoLabel.TextStrokeTransparency = 0; infoLabel.Parent = bb
	end

	if bb:FindFirstChild("RPName") then
		bb.RPName.Text = tostring(newName or character.Name)
		bb.RPName.TextColor3 = Color3.fromRGB(255,255,255)
	end

	local gattr = safeGetAttribute(character, "Gender")
	local aattr = safeGetAttribute(character, "Age")
	if (not gattr or not aattr) then
		local ply = Players:GetPlayerFromCharacter(character)
		if ply and PlayerIdentity[ply.UserId] then
			gattr = gattr or PlayerIdentity[ply.UserId].Gender
