local function getRandomAnimName()
	local categories = animsFolder:GetChildren()
	if #categories == 0 then return nil end
	local randomCat = categories[math.random(1, #categories)]
	if randomCat:IsA("Folder") then
		local anims = randomCat:GetChildren()
		if #anims == 0 then return nil end
		return anims[math.random(1, #anims)].Name
	end
	return nil
end

local function CleanupFinisher(finisherId)
	local data = ActiveFinishers[finisherId]
	if not data then return end

	if data.Connections then
		for _, c in ipairs(data.Connections) do if c.Connected then c:Disconnect() end end
	end

	local fPlayer = data.Finisher
	local vPlayer = data.Victim
	local fChar = fPlayer and fPlayer.Character
	local vChar = vPlayer and (vPlayer:IsA("Player") and vPlayer.Character or vPlayer)

	stopCurrentAnimation(fPlayer)
	stopCurrentAnimation(vPlayer)

	restoreClothes(data)
	removeSpawnedMorphs(data)

	if fChar then
		local fHrp = fChar:FindFirstChild("HumanoidRootPart")
		if fHrp then fHrp.Anchored = false end
		fChar:SetAttribute("Invincible", false)
		fChar:SetAttribute("InFinisher", false)

		if not fChar:GetAttribute("IsRagdolled") then
			GiveSword(fPlayer)
		end
	end

	if vChar then
		local vHrp = vChar:FindFirstChild("HumanoidRootPart")
		if vHrp then vHrp.Anchored = false end
		vChar:SetAttribute("Invincible", false)
		vChar:SetAttribute("InFinisher", false)

		local vHum = vChar:FindFirstChild("Humanoid")
		if vHum and vHum.Health > 0 and data.Finished then
			vHum.Health = 0
		end

		if vHum and vHum.Health <= 75 or data.Finished then
			Ragdoll.RagdollCharacter(vChar)
		else
			if vPlayer:IsA("Player") then GiveSword(vPlayer) end
		end
	end
	vHrp.Parent.Humanoid.AutoRotate = true
	fHrp.Parent.Humanoid.AutoRotate = true
	ActiveFinishers[finisherId] = nil
end

local function StartFinisherSequence(finisherPlayer, victimPlayer)
	if ActiveFinishers[finisherPlayer.UserId] then return end
	if victimPlayer:IsA("Player") and ActiveFinishers[victimPlayer.UserId] then return end

	local fChar = finisherPlayer.Character
	local vChar = victimPlayer:IsA("Player") and victimPlayer.Character or victimPlayer
	if not fChar or not vChar then return end

	local fHrp = fChar:FindFirstChild("HumanoidRootPart")
	local vHrp = vChar:FindFirstChild("HumanoidRootPart")
	local fHum = fChar:FindFirstChild("Humanoid")
	local vHum = vChar:FindFirstChild("Humanoid")

	if not fHrp or not vHrp or not fHum or not vHum then return end

	local fGender = getPlayerGender(finisherPlayer)
	local vGender = "male"
	if victimPlayer:IsA("Player") then 
		vGender = getPlayerGender(victimPlayer) 
	else 
		local gAttr = safeGetAttribute(victimPlayer, "Gender")
		if gAttr then vGender = genderCategory(gAttr) end
	end

	-- GIRL X GIRL INSTANT KILL LOGIC
	if fGender == "female" and vGender == "female" then
		vHum.Health = 0
		if finisherPlayer:FindFirstChild("leaderstats") and finisherPlayer.leaderstats:FindFirstChild("Kills") then
			finisherPlayer.leaderstats.Kills.Value += 1
		end
		return -- Exit early, do not start finisher animations
	end

	-- ==========================================
	-- TRIGGER LOADING SCREEN & WAIT
	-- ==========================================
	local loadingDuration = 2.5 -- Seconds the black screen lasts

	if finisherPlayer then
		FinisherLoadingEvent:FireClient(finisherPlayer, loadingDuration)
	end
	if victimPlayer:IsA("Player") then
		FinisherLoadingEvent:FireClient(victimPlayer, loadingDuration)
	end

	-- Anchor immediately so they don't move while the screen is blacking out
	fHrp.Anchored = true
	vHrp.Anchored = true

	-- Wait for the client UI to cover the screen before teleporting
	task.wait(loadingDuration * 0.4) 

	-- ==========================================
	-- SETUP & TELEPORT (Hidden from view)
	-- ==========================================
	RemoveSword(finisherPlayer)
	if victimPlayer:IsA("Player") then RemoveSword(victimPlayer) end

	Ragdoll.UnRagdollCharacter(vChar)

	fChar:SetAttribute("Invincible", true)
	vChar:SetAttribute("Invincible", true)
	fChar:SetAttribute("InFinisher", true)
	vChar:SetAttribute("InFinisher", true)

	-- PRIORITY & POSITIONING LOGIC (Femboy > Female > Male)
	local priorities = {femboy = 3, female = 2, male = 1, neutral = 1}
	local fPri = priorities[fGender] or 1
	local vPri = priorities[vGender] or 1

	local fRole = "Standard"
	local vRole = "Standard"

	if fGender == "femboy" then fRole = "Serious" end
	if vGender == "femboy" then vRole = "Serious" end
	if fGender == "female" and vGender == "male" then fRole = "Serious" end
	if vGender == "female" and fGender == "male" then vRole = "Serious" end

	if fRole == vRole then
		if fRole == "Standard" then vRole = "Serious" else vRole = "Standard" end
	end

	local forward = fHrp.CFrame.LookVector
	local victimPos

	vHrp.Parent.Humanoid.AutoRotate = false
	fHrp.Parent.Humanoid.AutoRotate = false
	vHrp.CFrame = fHrp.CFrame

	local data = {
		Finisher = finisherPlayer,
		Victim = victimPlayer,
		StoredClothes = {},
		SpawnedHats = {},
		Connections = {},
		Finished = false
	}
	ActiveFinishers[finisherPlayer.UserId] = data

	hideClothes(fChar, data)
	hideClothes(vChar, data)
	spawnMorphsForPair(fChar, vChar, data)

	-- ==========================================
	-- PLAY ANIMATIONS
	-- ==========================================
	local animName = getRandomAnimName()
	if animName and Animator then
		local fAnim = getAnimFromFolder(animName, fRole)
		local vAnim = getAnimFromFolder(animName, vRole)

		if fAnim then pcall(function() Animator.PlayAnimation(finisherPlayer, fAnim, fChar, false) end) end
		if vAnim then pcall(function() Animator.PlayAnimation(victimPlayer, vAnim, vChar, false) end) end
	end

	table.insert(data.Connections, fHum.Died:Connect(function() CleanupFinisher(finisherPlayer.UserId) end))
	table.insert(data.Connections, vHum.Died:Connect(function() CleanupFinisher(finisherPlayer.UserId) end))
	table.insert(data.Connections, Players.PlayerRemoving:Connect(function(p)
		if p == finisherPlayer or p == victimPlayer then CleanupFinisher(finisherPlayer.UserId) end
	end))

	-- ==========================================
	-- TIMING & CLEANUP LOOP
	-- ==========================================
	task.spawn(function()
		local t = 0
		while ActiveFinishers[finisherPlayer.UserId] == data and t < 30 do
			task.wait(1)
			t += 1

			if t == 20 then
				changeSpeedForChar(fChar, 1.2)
				changeSpeedForChar(vChar, 1.2)
			elseif t == 40 then
				changeSpeedForChar(fChar, 2.0)
				changeSpeedForChar(vChar, 2.0)
			elseif t == 60 then
				changeSpeedForChar(fChar, 2.0)
				changeSpeedForChar(vChar, 2.0)
			elseif t == 75 then
				changeSpeedForChar(fChar, 3.0)
				changeSpeedForChar(vChar, 3.0)
			elseif t == 85 then
				changeSpeedForChar(fChar, 0.25)
				changeSpeedForChar(vChar, 0.25)
			elseif t == 95 then
				data.Finished = true
				if finisherPlayer:FindFirstChild("leaderstats") and finisherPlayer.leaderstats:FindFirstChild("Kills") then
					finisherPlayer.leaderstats.Kills.Value += 1
				end
				CleanupFinisher(finisherPlayer.UserId)
			end
		end
	end)
end

